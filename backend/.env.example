# ─────────────────────────────────────────────────────────────────────────────
# AGENT 05 — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production          # "development" | "production"
FRONTEND_URL=https://yourdomain.com   # ← Your frontend URL (for CORS)

# ── Perplexity API ────────────────────────────────────────────────────────────
# Get your key at: https://www.perplexity.ai/settings/api
# Used for: deep web research, pulling sources, academic papers, trade reports
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # ← PASTE YOUR KEY HERE

# ── Anthropic / Claude API ────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/settings/keys
# Used for: outline generation, executive summary, introduction draft
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # ← PASTE YOUR KEY HERE

# ── Notion API ────────────────────────────────────────────────────────────────
# Create an integration at: https://www.notion.so/my-integrations
# Then share your target database with the integration.
# Used for: saving brief, outline, draft, citations to Notion database
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # ← PASTE YOUR KEY HERE
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx              # ← Your Notion DB ID (32-char hex from URL)

# ── Optional: DOI / CrossRef Validation ──────────────────────────────────────
# CrossRef is free — no key needed. Zotero also works without auth.
# Set to "true" to enable citation validation (recommended)
ENABLE_CITATION_VALIDATION=true

# ── Security ──────────────────────────────────────────────────────────────────
# Random string for signing session tokens (run: openssl rand -hex 32)
SESSION_SECRET=replace_with_random_64char_hex_string   # ← GENERATE AND PASTE HERE
